{
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  },
  "containerEnv": {
    "LANG": "en_US.UTF-8",
    "LC_ALL": "en_US.UTF-8"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind",
  "workspaceFolder": "${localWorkspaceFolder}",
  "mounts": [
    "type=bind,source=/var/run/docker.sock,target=/var/run/docker.sock",
    "type=volume,source=devcontainer-brew,target=/home/linuxbrew/.linuxbrew",
    "type=volume,source=devcontainer-cargo-registry,target=/home/vscode/.cargo/registry",
    "type=volume,source=devcontainer-pip-cache,target=/home/vscode/.cache/pip",
    "type=volume,source=devcontainer-npm-cache,target=/home/vscode/.npm",
    "type=volume,source=devcontainer-nvim-data,target=/home/vscode/.local/share/nvim"
  ]
}
