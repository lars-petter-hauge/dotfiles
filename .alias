# File handling and moving around
alias cd..="cd .."
alias ls="ls --color=auto"
alias ll="ls -l --color=auto"
alias l.="ls -d .* --color=auto"

# General
alias tree="tree -C"
alias python="python3"
alias curl="curl -w '\n'" # Add newline after response

# Git
alias glog="git log --graph --color=always --format=\"%C(auto)%h%d %s %C(green)%C(bold)%cr\""

# Search
function rf() {
    bash "$(dirname "$(readlink "$HOME/.alias")")/ripfzf.sh"
}

# Dev container
function dev() {
  if ! docker image inspect devimage:latest >/dev/null 2>&1; then
    echo "devimage not found, building..."
    local dotfiles_dir="$(dirname "$(readlink "$HOME/.alias")")"
    docker build -f "$dotfiles_dir/Dockerfile.dev" -t devimage "$dotfiles_dir" || return 1
  fi
  if [[ "$(uname)" == "Darwin" ]]; then
    ssh_args="--mount type=bind,src=/run/host-services/ssh-auth.sock,target=/ssh-agent -e SSH_AUTH_SOCK=/ssh-agent"
  else
    ssh_args="-v $SSH_AUTH_SOCK:/ssh-agent -e SSH_AUTH_SOCK=/ssh-agent"
  fi
  docker run -it --rm \
    -v "$PWD":/workspace \
    -v /var/run/docker.sock:/var/run/docker.sock \
    $ssh_args \
    -w /workspace devimage /bin/bash -lc tmux
}
