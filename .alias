# File handling and moving around
alias cd..="cd .."
alias ls="ls --color=auto"
alias ll="ls -l --color=auto"
alias l.="ls -d .* --color=auto"

# General
alias tree="tree -C"
alias python="python3"
alias curl="curl -w '\n'" # Add newline after response

# Git
alias glog="git log --graph --color=always --format=\"%C(auto)%h%d %s %C(green)%C(bold)%cr\""

alias watchlg="watch -n 1 --color git lg --color=always"
alias watchdiff="watch -n 1 --color git diff -U0 --color=always"
alias watchstaged="watch -n 1 --color git diff -U0 --staged --color=always"
alias watchtree="watch -n 1 --color tree .git/objects"

decomp() {
  [ -f "$1" ] || { echo "usage: decomp <file>" >&2; return 1; }
  python3 -c 'import sys,zlib; sys.stdout.buffer.write(zlib.decompress(open(sys.argv[1],"rb").read()))' "$1"
}

rand_word_commit() {
  COUNT="$1"

  for ((i = 1; i <= COUNT; i++)); do
    rand=$(shuf -n 1 /usr/share/dict/words)
    sed -i "s/{[^}]*}/{ $rand }/g" $2
    git add $2
    git commit -m "Update random word to: $rand"

    echo "Commit $i: set word to '$rand'"
  done
  }

_FUNCTIONS_DIR="$(dirname "$(readlink -f "${(%):-%x}")")"

lorem_impsum(){
  cat "$_FUNCTIONS_DIR/lorem_ipsum"
  }
